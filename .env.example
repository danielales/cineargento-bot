# .env.local — CineArgento Bot
# Copiar este archivo como .env.local y completar los valores
# NUNCA subir este archivo a git

# ─── Meta / WhatsApp ─────────────────────────────────────────────────────────
# Token de verificación del webhook (inventalo vos, cualquier string)
WHATSAPP_VERIFY_TOKEN=cineargento_webhook_2024

# Token de acceso de la app de Meta (Meta for Developers → tu app → WhatsApp → API Setup)
WHATSAPP_ACCESS_TOKEN=

# ID del número de teléfono de WhatsApp (Meta for Developers → WhatsApp → API Setup)
WHATSAPP_PHONE_NUMBER_ID=

# ─── Anthropic Claude ────────────────────────────────────────────────────────
# Claude API key (console.anthropic.com)
ANTHROPIC_API_KEY=

# ─── Supabase ────────────────────────────────────────────────────────────────
# URL del proyecto (Supabase Dashboard → Settings → API)
SUPABASE_URL=

# Service role key — NUNCA exponerla en el cliente
SUPABASE_SERVICE_ROLE_KEY=
